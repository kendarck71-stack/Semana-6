Algoritmo ValidarRango
    Definir num Como Real
    num <- 5 // Inicializamos con un valor válido para entrar al bucle
    
    Mientras num >= 1 Y num <= 10 Hacer
        Escribir "Ingrese un número entre 1 y 10 (fuera de rango para salir):"
        Leer num
    Fin Mientras
    
    Escribir "Número inválido detectado. Saliendo del programa..."
FinAlgoritmo
